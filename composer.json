{
    "name": "chieftools/sdk",
    "description": "Base functionality and helpers used for building Chief Tools.",
    "homepage": "https://chief.app",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.9",
        "laracasts/utilities": "^3.2",
        "laravel/framework": "^12.20|^13.2",
        "laravel/helpers": "^1.7",
        "laravel/socialite": "^5.20",
        "mll-lab/graphql-php-scalars": "^6.4",
        "nuwave/lighthouse": "^6.66",
        "pusher/pusher-php-server": "^7.2",
        "sentry/sentry-laravel": "^4.15",
        "stayallive/laravel-eloquent-observable": "^1.1",
        "stayallive/laravel-eloquent-uuid": "^1.0",
        "stayallive/random-tokens": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.84",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.1|^11",
        "pestphp/pest": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "ChiefTools\\SDK\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ChiefTools\\SDK\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "cs": [
            "@phpcs"
        ],
        "stan": "@phpstan",
        "check": [
            "@test",
            "@phpcs",
            "@phpstan"
        ],
        "test": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/pest --parallel --stop-on-failure"
        ],
        "test:ci": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/pest --ci --parallel --compact"
        ],
        "test:unit": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/pest --testsuite Unit --parallel --stop-on-failure"
        ],
        "test:feature": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/pest --testsuite Feature --parallel --stop-on-failure"
        ],
        "phpcs": "vendor/bin/php-cs-fixer fix",
        "phpcs:ci": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "phpstan:ci": "vendor/bin/phpstan analyse --memory-limit=2G --error-format=github"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": false,
            "pestphp/pest-plugin": true
        },
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true
    }
}
