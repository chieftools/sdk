        "./resources/js/confirm.js",
        "./resources/js/livewire.js",
        "./resources/js/tooltips.js"
    ],
    "devDependencies": {
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.7.3"
