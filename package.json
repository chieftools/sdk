{
    "name": "@chieftools/sdk",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "prettier": "prettier --write 'resources/{css,js}/{**/*,*}.{js,vue,css,less,scss,gql,graphql}'",
        "prettier:ci": "prettier --check 'resources/{css,js}/{**/*,*}.{js,vue,css,less,scss,gql,graphql}'"
    },
    "exports": {
        "./clipboard": "./resources/js/clipboard.js",
        "./confirm": "./resources/js/confirm.js",
        "./dom": "./resources/js/dom.js",
        "./livewire": "./resources/js/livewire.js",
        "./tooltips": "./resources/js/tooltips.js",
        "./shell": "./resources/js/shell/index.js"
    },
    "sideEffects": [
